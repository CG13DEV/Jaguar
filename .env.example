# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_CDN_URL: Optional CDN url to load media assets from
VITE_CDN_URL=""

# VITE_FEATURE_MEDIA_INTERVAL_MS: Feature media autoplay interval in milliseconds
VITE_FEATURE_MEDIA_INTERVAL_MS="6000"
